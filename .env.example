# LocalAgent Desktop — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit the .env file!

# ===== LLM Provider API Keys =====
# Only fill in the providers you plan to use.

# OpenRouter (cloud models: Claude, GPT, Mistral, etc.)
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# OpenAI / OpenAI-compatible endpoint
OPENAI_API_KEY=

# Qwen (Alibaba Cloud)
QWEN_API_KEY=

# ===== Local Provider Hosts =====
# These are the default values. Change only if your setup differs.

# Ollama (default: http://localhost:11434)
# OLLAMA_HOST=localhost:11434

# LM Studio (default: http://localhost:1234)
# LMSTUDIO_HOST=localhost:1234

# ===== Telegram Bot (optional) =====
# TELEGRAM_BOT_TOKEN=

# ===== Docker =====
# When running in Docker, Ollama host should be:
# OLLAMA_HOST=host.docker.internal:11434
