{
  "name": "localagent-desktop",
  "version": "1.0.0",
  "description": "Standalone desktop AI agent with calendar integration and MCP tooling",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "start:test:external": "electron . --external-test --windowless --external-port 8788",
    "start:test:nowindow": "node src/main/main.js --test --nowindow",
    "dev": "concurrently \"npm run start\" \"npm run watch\"",
    "build": "electron-builder",
    "watch": "nodemon --watch src --ext js,html,css --exec \"npm start\"",
    "check:skins": "node tools/check-skins.js",
    "test:contracts": "node tests/run-suite.js contracts",
    "test:quick": "node tests/run-suite.js quick",
    "test:skin": "node tests/run-suite.js skin",
    "test:skins:apply": "node tools/test-skin-apply.js",
    "test:headless": "npm run test:skin",
    "test:ipc-handlers": "node tools/test-ipc-registration.js",
    "test:plugin-knowledge": "node tools/test-plugin-knowledge-managers.js",
    "test:dispatcher-mocked": "node tools/test-dispatcher-mocked.js",
    "test:ipc-flow-mocked": "node tools/test-ipc-flow-mocked.js",
    "test:tool-lifecycle": "node tools/test-tool-routing-lifecycle.js",
    "test:testclient-mode": "node tools/test-testclient-mode.js",
    "test:searxng-smoke": "node tools/test-searxng-plugin-smoke.js",
    "test:searxng-e2e": "electron tools/test-searxng-e2e-electron.js",
    "test:tts-fast-qwen-smoke": "node tools/test-tts-plugin-fast-qwen-smoke.js",
    "test:tts-piper-smoke": "node tools/test-tts-plugin-piper-smoke.js",
    "test:rag-superagent": "node tools/test-rag-superagent-flow.js",
    "test:subagent-external": "node tests/external/subagent-dual-mode.external-test.js",
    "test:subagent-live-search": "node tests/external/subagent-live-search.external-test.js",
    "test:subagent-live-time": "node tests/external/subagent-live-time.external-test.js",
    "test:ollama-live": "node tools/test-ollama-live.js",
    "test:live": "node tests/run-suite.js live",
    "test:core": "node tests/run-suite.js core",
    "test:all": "node tests/run-suite.js all",
    "verify": "node tests/run-suite.js core"
  },
  "keywords": [
    "electron",
    "ai",
    "calendar",
    "mcp",
    "desktop"
  ],
  "author": "LocalAgent",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "electron-rebuild": "^3.2.9",
    "nodemon": "^3.0.1"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "better-sqlite3": "^9.0.1",
    "lru-cache": "^7.18.3",
    "node-fetch": "^2.7.0"
  },
  "build": {
    "appId": "com.localagent.desktop",
    "productName": "LocalAgent Desktop",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "extraFiles": [
      {
        "from": "agentin",
        "to": "agentin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "sign": false
    },
    "asar": true
  }
}
