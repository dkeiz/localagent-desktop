FROM node:20-slim

# ── 1. System dependencies for Electron + virtual display + VNC ──
RUN apt-get update && apt-get install -y --no-install-recommends \
    # Build tools for native modules (better-sqlite3)
    python3 make g++ \
    # Electron / Chromium runtime deps
    libgtk-3-0 libnotify4 libnss3 libxss1 libxtst6 xdg-utils \
    libatspi2.0-0 libdrm2 libgbm1 libasound2 libx11-xcb1 \
    libxcomposite1 libxdamage1 libxrandr2 libxfixes3 libcups2 \
    libpango-1.0-0 libcairo2 libdbus-1-3 libexpat1 libfontconfig1 \
    libgcc-s1 libglib2.0-0 libnspr4 libpangocairo-1.0-0 \
    libstdc++6 libx11-6 libxcb1 libxext6 fonts-liberation \
    fonts-noto-color-emoji fonts-noto-cjk fonts-dejavu-core \
    ca-certificates wget \
    # Virtual display + VNC
    xvfb x11vnc novnc websockify \
    # Supervisor to manage all processes
    supervisor \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# ── 2. Install Node dependencies (including Electron as a dev dep) ──
COPY package.json ./
RUN npm install
# Rebuild native modules (better-sqlite3) for Electron's Node ABI
RUN npx electron-rebuild -f -w better-sqlite3

# ── 3. Copy application source ──
COPY src/ ./src/
COPY agentin/ ./agentin/

# ── 4. Create runtime directories ──
RUN mkdir -p \
    agentin/workspaces \
    agentin/memory/daily \
    agentin/memory/global \
    agentin/memory/images \
    agentin/memory/tasks \
    agentin/subtasks/runs \
    agentin/research/runs \
    agentin/workflows/runs \
    agentin/knowledge/staging \
    data

# ── 5. Startup script & supervisor config ──
COPY docker/gui-start.sh /usr/local/bin/gui-start.sh
RUN chmod +x /usr/local/bin/gui-start.sh

COPY docker/supervisord.conf /etc/supervisor/conf.d/localagent.conf

# ── 6. Ports ──
# 6080 = noVNC web UI (access GUI via browser)
# 8788 = API (same as headless mode)
EXPOSE 6080 8788

# ── 7. Environment ──
ENV DISPLAY=:99
ENV ELECTRON_DISABLE_SANDBOX=1
ENV ELECTRON_NO_ATTACH_CONSOLE=1

CMD ["/usr/bin/supervisord", "-c", "/etc/supervisor/conf.d/localagent.conf"]
